# ─── Database ────────────────────────────────────────────────────────────────
DB_PROVIDER="postgresql"
DATABASE_URL="postgresql://user:password@localhost:5432/voiceai"
# DB_PROVIDER="sqlite"
# DATABASE_URL="file:./dev.db"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── OpenRouter (FREE AI — replaces OpenAI) ───────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Which free model to use as the platform default.
# See all free models at: https://openrouter.ai/models?q=:free
# Recommended free models:
#   meta-llama/llama-3.1-8b-instruct:free    (fast, great for conversation)
#   mistralai/mistral-7b-instruct:free        (reliable, good quality)
#   google/gemma-2-9b-it:free                 (Google model, very capable)
#   nousresearch/hermes-3-llama-3.1-405b:free (most capable free model)
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# ─── Twilio (required for making phone calls) ─────────────────────────────────
# Get credentials at: https://twilio.com — free trial gives ~$15 credit
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ─── App URL ──────────────────────────────────────────────────────────────────
# For local dev with Twilio webhooks, use ngrok: https://ngrok.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
